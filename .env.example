# Application
NODE_ENV=production
PORT=3000
APP_VERSION=2.4.1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orion_db
DB_USER=orion_user
DB_PASS=changeme

# Auth
JWT_SECRET=super-secret-jwt-key-change-in-prod
SESSION_TIMEOUT=3600

# External Services
PAYMENT_SERVICE_URL=https://payments.internal.orion.io
NOTIFICATION_SERVICE_URL=https://notify.internal.orion.io
ANALYTICS_ENDPOINT=https://analytics.internal.orion.io/ingest

# Deployment
DEPLOY_TARGET=production
REGISTRY=gcr.io/orion-platform
IMAGE_TAG=latest

# Monitoring
LOG_LEVEL=warn
SENTRY_DSN=
DATADOG_API_KEY=
